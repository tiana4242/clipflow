{
  "name": "Clip Flow - Smart Video Clipper",
  "short_name": "Clip Flow",
  "description": "AI-powered video clipping, trimming, and sharing tool with offline support",
  "start_url": "/",
  "id": "/",
  "display": "standalone",
  "background_color": "#0f172a",
  "theme_color": "#0f172a",
  "orientation": "any",
  "scope": "/",
  "lang": "en",
  "categories": ["video", "productivity", "social", "utilities"],
  "icons": [
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/desktop-wide.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Clip Flow desktop interface showing video editing workspace"
    },
    {
      "src": "/screenshots/mobile-narrow.png", 
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Clip Flow mobile interface with video library"
    }
  ],
  "share_target": {
    "action": "/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "video",
          "accept": ["video/*", "video/mp4", "video/webm", "video/quicktime"]
        }
      ]
    }
  },
  "shortcuts": [
    {
      "name": "New Clip",
      "short_name": "Clip",
      "description": "Start creating a new video clip",
      "url": "/?action=new-clip",
      "icons": [{ "src": "/icons/icon-192x192.png", "sizes": "192x192" }]
    },
    {
      "name": "My Clips",
      "short_name": "Library",
      "description": "View your saved clips",
      "url": "/?action=library",
      "icons": [{ "src": "/icons/icon-192x192.png", "sizes": "192x192" }]
    }
  ]
}